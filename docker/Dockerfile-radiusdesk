FROM jtreminio/php:8.1@sha256:5d33f361015f910ad3cb270f2b2c574e1a8bf329ff65d7b157f3298eae9d0018

## Install all software required

# Install all required packages in a single layer and clean up apt metadata.
RUN apt-get update && apt-get install -y --no-install-recommends \
    language-pack-en-base \
    nginx \
    libdatetime-perl \
    freeradius \
    freeradius-mysql \
    supervisor \
    subversion \
  && rm -rf /var/lib/apt/lists/*

# Prepare all directories
COPY ./docker/default /etc/nginx/sites-enabled/
COPY ./radiusdesk/rdcore /var/www/rdcore

RUN mkdir -p /var/www/html && \
    ln -s /var/www/rdcore/rd /var/www/html/rd && \
    ln -s /var/www/rdcore/cake4 /var/www/html/cake4 && \
    # If backward compatibility is required for older firmware of MESHdesk
    ln -s /var/www/rdcore/cake4 /var/www/html/cake3 && \
    ln -s /var/www/rdcore/login /var/www/html/login && \
    ln -s /var/www/rdcore/AmpConf/build/production/AmpConf /var/www/html/conf_dev && \
    ln -s /var/www/rdcore/login/rd_client/build/production/AmpConf /var/www/html/usage && \
    ln -s /var/www/rdcore/cake4/rd_cake/setup/scripts/reporting /var/www/html/reporting && \
    mkdir -p /var/www/html/cake4/rd_cake/logs && \
    mkdir -p /var/www/html/cake4/rd_cake/webroot/files/imagecache && \
    mkdir -p /var/www/html/cake4/rd_cake/tmp && \
    chown -R www-data:www-data /var/www/html/cake4/rd_cake/tmp && \
    chown -R www-data:www-data /var/www/html/cake4/rd_cake/logs && \
    chown -R www-data:www-data /var/www/html/cake4/rd_cake/webroot/img/realms && \
    chown -R www-data:www-data /var/www/html/cake4/rd_cake/webroot/img/dynamic_details && \
    chown -R www-data:www-data /var/www/html/cake4/rd_cake/webroot/img/dynamic_photos && \
    chown -R www-data:www-data /var/www/html/cake4/rd_cake/webroot/img/access_providers && \
    chown -R www-data:www-data /var/www/html/cake4/rd_cake/webroot/img/hardwares && \
    chown -R www-data:www-data /var/www/html/cake4/rd_cake/webroot/files/imagecache

## Setup environment variables
ENV PHP_INI_SCAN_DIR=:/p/gd
ENV PHP.cgi.fix_pathinfo=1
ENV PHP_SELF=/index.php

## Setup Cron jobs
RUN cp /var/www/html/cake4/rd_cake/setup/cron/cron4 /etc/cron.d/ && \
    chmod 0644 /etc/cron.d/cron4 && \
    crontab /etc/cron.d/cron4

# Configure php-fpm
RUN mkdir -p /var/log/php-fpm

## Configure freeradius
RUN mv /etc/freeradius /etc/freeradius.orig && \
    mkdir -p /etc/freeradius && \
    tar xzf /var/www/html/cake4/rd_cake/setup/radius/freeradius-3-radiusdesk.tar.gz --one-top-level=/etc/freeradius/ && \
    mv /etc/freeradius/freeradius /etc/freeradius/3.0 && \
    chown -R freerad:freerad /etc/freeradius/3.0/ && \
    mkdir -p /var/run/freeradius && \
    chown freerad:freerad /var/run/freeradius

COPY ./docker/freeradius.service /lib/systemd/system/

# supervisord allows multiple processes to be started with a single process
COPY ./docker/supervisord.conf /etc/supervisor/conf.d/supervisord.conf

# Copy php settings to the FPM and CLI paths used by the Ondřej Surý packages.
COPY ./docker/php.ini /etc/php/8.1/fpm/php.ini
COPY ./docker/php.ini /etc/php/8.1/cli/php.ini

# Fix the configs to point to external database
RUN sed -i "s/'host' => 'localhost'/'host' => 'rdmariadb'/g" /var/www/html/cake4/rd_cake/config/app_local.php && \
    sed -i "s/\$servername = \"localhost\";/\$servername = \"rdmariadb\";/g" /var/www/rdcore/cake4/rd_cake/setup/scripts/reporting/reporting.php && \
    sed -i "s/\$servername = \"localhost\";/\$servername = \"rdmariadb\";/g" /var/www/rdcore/cake4/rd_cake/setup/scripts/reporting/flows_wip.php && \
    sed -i "s/\$servername = \"localhost\";/\$servername = \"rdmariadb\";/g" /var/www/rdcore/cake4/rd_cake/setup/scripts/reporting/process_flows.php && \
    sed -i "s/\$servername = \"localhost\";/\$servername = \"rdmariadb\";/g" /var/www/rdcore/cake4/rd_cake/setup/scripts/reporting/process_report.php && \
    sed -i "s/\$servername = \"localhost\";/\$servername = \"rdmariadb\";/g" /var/www/rdcore/cake4/rd_cake/setup/scripts/reporting/reporting_wip.php && \
    sed -i "s/\$servername = \"localhost\";/\$servername = \"rdmariadb\";/g" /var/www/rdcore/cake4/rd_cake/setup/scripts/reporting/send_remote_syslog.php && \
    sed -i 's/server = "localhost"/server = "rdmariadb"/g' /etc/freeradius/3.0/mods-available/sql

# Copy files from production to root www
RUN cp -R /var/www/html/rd/build/production/Rd/* /var/www/html/

# Entrypoint run script when container starts
ENTRYPOINT ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/supervisord.conf"]

EXPOSE 80/tcp
EXPOSE 1812/udp
EXPOSE 1813/udp
